# Copy to .env.local for local dev. These are PUBLIC (client-exposed) by design —
# they only carry the backend's base URLs, no secrets.
#
# Two supported topologies:
#
# 1) PROD / nginx (same-origin) — the React app and backend share an origin; nginx
#    proxies /api/* → backend and /api/ws/* → backend WS. Use RELATIVE bases; the
#    WS base is resolved to ws(s)://<page-host>/api at runtime.
#      NEXT_PUBLIC_API_BASE=/api
#      NEXT_PUBLIC_WS_BASE=/api
#
# 2) LOCAL dev pointing straight at the backend (e.g. uvicorn/compose on :8001).
#    Cross-origin, so the backend must allow CORS for browser calls (a CLI client
#    is unaffected). Use ABSOLUTE bases:
#      NEXT_PUBLIC_API_BASE=http://localhost:8001
#      NEXT_PUBLIC_WS_BASE=ws://localhost:8001

NEXT_PUBLIC_API_BASE=/api
NEXT_PUBLIC_WS_BASE=/api
