# Copy to .env and fill in real values. Never commit .env.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=machikoro
MYSQL_USER=machiuser
MYSQL_PASSWORD=change-me

# --- Game WebSocket auth (TASK-002) ---
# Shared HMAC-SHA256 secret used by WordPress to sign per-seat game tokens and
# by the websocket server to verify them. MUST be identical for both services.
# Generate a strong value with:  openssl rand -hex 32
MK_WS_SECRET=replace-with-openssl-rand-hex-32
