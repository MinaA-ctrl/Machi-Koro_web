# Copy to .env and fill in real values. Never commit .env.

# --- MySQL — WordPress core only (pages/posts); not the game data ---
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=machikoro
MYSQL_USER=machiuser
MYSQL_PASSWORD=change-me

# --- Backend: Postgres (game data, accounts, entitlements) ---
# Used by the `postgres` + `backend` services (the backend reads these as DB_*).
POSTGRES_DB=machikoro
POSTGRES_USER=machikoro
POSTGRES_PASSWORD=change-me-postgres

# --- Backend: JWT auth ---
# Signs JWT access/refresh tokens (HS256). REQUIRED — with MK_ENV=prod the backend
# refuses to boot if this is unset or left at its insecure dev default.
# Generate with:  openssl rand -hex 32
MK_JWT_SECRET=replace-with-openssl-rand-hex-32

# --- Backend: per-seat game-WS token (TASK-002) ---
# HMAC-SHA256 secret the backend uses to sign per-seat WS tokens (in REST) and
# verify them (on the socket). REQUIRED in prod. Generate with: openssl rand -hex 32
MK_WS_SECRET=replace-with-openssl-rand-hex-32

# --- Backend: runtime ---
# The compose `backend` service sets MK_ENV=prod (enforces real secrets + turns on
# rate limiting). Set MK_RATE_LIMIT=on to force rate limiting outside prod.
# MK_ENV=prod
# MK_RATE_LIMIT=on
